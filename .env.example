NEXT_PUBLIC_API_URL=http://localhost:8080

# Odoo read-only sync (server-side only — never exposed to the browser)
# ODOO_URL: base domain only — do NOT include /odoo or /web suffix
ODOO_URL=https://your-odoo-instance.odoo.com
# ODOO_DB: full database name — check via POST /web/database/list if unsure
ODOO_DB=your-db-production-12345678
# ODOO_USERNAME: the Odoo user login email whose API key is used (must match the key below)
ODOO_USERNAME=admin@yourcompany.com
ODOO_API_KEY=your_odoo_api_key
